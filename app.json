{
  "expo": {
    "name": "Kohrvellia",
    "slug": "kohrvellia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kohrvellia.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.kohrvellia.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "scheme": "kohrvellia",
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font",
      "expo-audio"
    ],
    "experiments": {
      "baseUrl": "/Kohrvellia"
    }
  }
}
