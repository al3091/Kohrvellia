{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@/types": [
        "src/types"
      ],
      "@/stores": [
        "src/stores"
      ],
      "@/lib": [
        "src/lib"
      ],
      "@/constants": [
        "src/constants"
      ],
      "@/components": [
        "src/components"
      ],
      "@/data": [
        "src/data"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}
